<section class="px-6 md:px-12 py-16 md:py-20 bg-[#8B1A1A] min-h-screen">
  <div class="max-w-lg mx-auto">
    <p class="text-xs font-medium text-[#C9A96E] uppercase tracking-[0.15em] text-center mb-2">Almost There</p>
    <h1 class="text-3xl md:text-4xl font-bold text-[#FAF3E8] text-center mb-4 tracking-tight">Checkout</h1>
    <p class="text-base text-[#FAF3E8]/60 text-center mb-10">Pay at pickup. We'll have your order ready.</p>

    <div class="bg-[#FAF3E8] rounded-lg p-8">
      <!-- Order Summary -->
      <div class="mb-6 pb-6 border-b border-[#C9A96E]/20">
        <h3 class="text-sm font-semibold text-[#3D2B1F] mb-3">Your Order</h3>
        <% @cart.items.each do |item_id, qty| %>
          <% item = @cart.menu_items[item_id.to_i] %>
          <% next unless item %>
          <div class="flex justify-between text-sm py-1">
            <span class="text-[#5A4A3F]"><%= qty %>× <%= item.name %></span>
            <span class="text-[#3D2B1F]">$<%= '%.2f' % (item.price * qty) %></span>
          </div>
        <% end %>
        <div class="flex justify-between text-sm font-bold pt-2 mt-2 border-t border-[#C9A96E]/20">
          <span>Total</span>
          <span><%= @cart.formatted_total %></span>
        </div>
      </div>

      <%= form_with(model: @order) do |f| %>
        <% if @order.errors.any? %>
          <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg">
            <% @order.errors.full_messages.each do |msg| %>
              <p class="text-sm text-red-700"><%= msg %></p>
            <% end %>
          </div>
        <% end %>

        <div class="space-y-4">
          <div>
            <%= f.label :customer_name, "Your Name", class: "block text-sm font-medium text-[#3D2B1F] mb-1" %>
            <%= f.text_field :customer_name, class: "w-full border border-[#C9A96E]/40 rounded px-3 py-2.5 bg-white text-[#3D2B1F] focus:ring-2 focus:ring-[#C9A96E] focus:border-[#C9A96E] outline-none text-sm" %>
          </div>
          <div>
            <%= f.label :phone, "Phone Number", class: "block text-sm font-medium text-[#3D2B1F] mb-1" %>
            <%= f.telephone_field :phone, class: "w-full border border-[#C9A96E]/40 rounded px-3 py-2.5 bg-white text-[#3D2B1F] focus:ring-2 focus:ring-[#C9A96E] focus:border-[#C9A96E] outline-none text-sm" %>
          </div>
          <div>
            <%= f.label :pickup_time, "Pickup Time", class: "block text-sm font-medium text-[#3D2B1F] mb-1" %>
            <%= f.time_field :pickup_time, class: "w-full border border-[#C9A96E]/40 rounded px-3 py-2.5 bg-white text-[#3D2B1F] focus:ring-2 focus:ring-[#C9A96E] focus:border-[#C9A96E] outline-none text-sm" %>
          </div>
        </div>

        <div class="mt-6">
          <%= f.submit "Place Order", class: "w-full bg-[#8B1A1A] text-[#FAF3E8] font-semibold py-3 rounded cursor-pointer hover:bg-[#6d1515] text-sm" %>
        </div>
      <% end %>
    </div>
  </div>
</section>
