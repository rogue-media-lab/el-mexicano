<section class="px-6 md:px-12 py-16 md:py-20 bg-[#FAF3E8] min-h-screen">
  <div class="max-w-lg mx-auto text-center">
    <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
      <span class="text-3xl">✓</span>
    </div>
    <h1 class="text-3xl font-bold text-[#3D2B1F] mb-4 tracking-tight">Order Placed!</h1>
    <p class="text-[#5A4A3F] mb-8">We'll have your order ready for pickup. Pay when you arrive.</p>

    <div class="bg-white rounded-lg p-6 shadow-sm text-left mb-8">
      <h3 class="text-sm font-semibold text-[#3D2B1F] mb-4 pb-2 border-b border-gray-100">Order #<%= @order.id %></h3>
      <div class="space-y-2 mb-4">
        <% @order.order_items.includes(:menu_item).each do |item| %>
          <div class="flex justify-between text-sm">
            <span class="text-[#5A4A3F]"><%= item.quantity %>× <%= item.menu_item.name %></span>
            <span class="text-[#3D2B1F]"><%= item.formatted_subtotal %></span>
          </div>
        <% end %>
      </div>
      <div class="flex justify-between font-bold text-[#3D2B1F] pt-3 border-t border-gray-100">
        <span>Total</span>
        <span><%= @order.formatted_total %></span>
      </div>
      <div class="mt-4 pt-3 border-t border-gray-100 text-sm text-[#5A4A3F]">
        <p><strong>Name:</strong> <%= @order.customer_name %></p>
        <p><strong>Phone:</strong> <%= @order.phone %></p>
        <% if @order.pickup_time %>
          <p><strong>Pickup:</strong> <%= @order.pickup_time.strftime('%l:%M %p')&.strip %></p>
        <% end %>
      </div>
    </div>

    <a href="/" class="text-sm font-semibold text-[#8B1A1A] bg-[#C9A96E] px-8 py-3 rounded">Back to Home</a>
  </div>
</section>
