<div class="mb-8">
  <%= link_to "← Back to testimonials", admin_testimonials_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
  <h2 class="text-2xl font-bold text-gray-900 mt-2"><%= @testimonial.new_record? ? "New Testimonial" : "Edit Testimonial" %></h2>
</div>

<div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 max-w-lg">
  <%= form_with(model: [:admin, @testimonial]) do |f| %>
    <% if @testimonial.errors.any? %>
      <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg">
        <% @testimonial.errors.full_messages.each do |msg| %>
          <p class="text-sm text-red-700"><%= msg %></p>
        <% end %>
      </div>
    <% end %>

    <div class="space-y-4">
      <div>
        <%= f.label :customer_name, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :customer_name, class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-amber-500 focus:border-amber-500 outline-none" %>
      </div>
      <div>
        <%= f.label :quote, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_area :quote, rows: 4, class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-amber-500 focus:border-amber-500 outline-none" %>
      </div>
      <div>
        <%= f.label :stars, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.select :stars, options_for_select([5, 4, 3, 2, 1], @testimonial.stars), {}, class: "w-24 border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-amber-500 focus:border-amber-500 outline-none" %>
      </div>
      <div class="flex items-center gap-6">
        <div class="flex items-center gap-2">
          <%= f.check_box :active, class: "rounded border-gray-300 text-amber-600 focus:ring-amber-500" %>
          <%= f.label :active, "Active", class: "text-sm text-gray-700" %>
        </div>
        <div class="flex items-center gap-2">
          <%= f.check_box :featured, class: "rounded border-gray-300 text-amber-600 focus:ring-amber-500" %>
          <%= f.label :featured, "Featured", class: "text-sm text-gray-700" %>
        </div>
      </div>
    </div>

    <div class="mt-6">
      <%= f.submit class: "bg-gray-900 text-white px-6 py-2 rounded-lg text-sm hover:bg-gray-800 cursor-pointer" %>
    </div>
  <% end %>
</div>
