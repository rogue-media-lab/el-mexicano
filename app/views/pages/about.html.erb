<section class="px-6 md:px-12 py-16 md:py-24 min-h-screen bg-cream">
  <div class="max-w-3xl mx-auto">
    <p class="text-xs font-medium uppercase tracking-[0.1em] mb-3 text-deep-red">Our Story</p>
    <h1 class="text-3xl md:text-5xl font-bold leading-tight tracking-tight mb-8 text-navy font-display"><%= @about_heading %></h1>
    <div class="text-base md:text-lg leading-relaxed space-y-6 text-brown">
      <% @about_body.split("\n\n").each do |para| %>
        <p><%= para %></p>
      <% end %>
    </div>

    <div class="mt-12 rounded-2xl overflow-hidden flex items-center justify-center bg-gradient-to-br from-gold to-deep-red min-h-[300px]">
      <div class="text-center">
        <%= image_tag "cactus.svg", class: "mx-auto mb-3 opacity-50 w-20" %>
        <p class="text-3xl font-bold text-white font-display">El Mexicano</p>
        <p class="text-sm text-white opacity-60 mt-2 uppercase tracking-wider">Clover, South Carolina</p>
      </div>
    </div>

    <div class="mt-8 p-8 rounded-2xl text-center bg-deep-red">
      <p class="text-sm uppercase tracking-wider text-white/60">Visit Us</p>
      <p class="text-lg font-semibold mt-2 text-gold">401 N Main St, Clover, SC 29710</p>
      <a href="/contact" class="inline-block mt-4 text-sm font-semibold text-navy px-8 py-3 rounded-full bg-gold hover:opacity-90">Get Directions</a>
    </div>
  </div>
</section>
