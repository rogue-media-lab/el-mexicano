<section class="px-6 md:px-12 py-16 md:py-24 bg-[#F5E6CC] min-h-screen">
  <div class="max-w-3xl mx-auto">
    <p class="text-xs font-medium text-[#8B1A1A] uppercase tracking-[0.1em] mb-3">Our Story</p>
    <h1 class="text-3xl md:text-5xl font-bold text-[#3D2B1F] leading-tight tracking-tight mb-8"><%= @about_heading %></h1>
    <div class="text-base md:text-lg text-[#5A4A3F] leading-relaxed space-y-6">
      <% @about_body.split("\n\n").each do |para| %>
        <p><%= para %></p>
      <% end %>
    </div>

    <div class="mt-12 rounded-lg overflow-hidden">
      <%= image_tag @storefront_image, alt: "Italian Garden Restaurant storefront", class: "w-full h-auto rounded-lg" %>
    </div>

    <div class="mt-8 p-8 bg-[#8B1A1A] rounded-lg text-center">
      <p class="text-sm text-[#FAF3E8]/60 uppercase tracking-wider">Visit Us</p>
      <p class="text-lg font-semibold text-[#C9A96E] mt-2">502 E Liberty St, York, SC 29745</p>
      <a href="/contact" class="inline-block mt-4 text-sm font-semibold text-[#8B1A1A] bg-[#C9A96E] px-8 py-3 rounded">Get Directions</a>
    </div>
  </div>
</section>
