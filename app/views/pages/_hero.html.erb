<%# Hero %>
<section class="flex flex-col items-center justify-center px-6 md:px-12 pt-16 md:pt-24 pb-32 md:pb-40 relative overflow-hidden wavy-texture bg-gold min-h-[620px]">
  <%# Decorative food SVGs %>
  <%= image_tag "taco.svg", class: "absolute opacity-40 pointer-events-none w-[140px] left-[5%] top-[20%] -rotate-15" %>
  <%= image_tag "burrito.svg", class: "absolute opacity-35 pointer-events-none w-[120px] right-[5%] top-[25%] rotate-10" %>
  <%= image_tag "nachos.svg", class: "absolute opacity-30 pointer-events-none w-[110px] left-[12%] bottom-[15%] -rotate-8" %>
  <%= image_tag "taco.svg", class: "absolute opacity-25 pointer-events-none w-[100px] right-[12%] bottom-[20%] rotate-20" %>

  <%# Centered text content %>
  <div class="max-w-2xl text-center z-10">
    <div class="w-16 h-1 rounded mb-6 mx-auto bg-deep-red"></div>
    <p class="text-sm font-medium uppercase tracking-[0.15em] mb-4 text-deep-red">Clover, South Carolina — Family Owned</p>
    <h1 class="text-4xl md:text-6xl font-bold leading-tight tracking-tight text-navy font-display"><%= @hero_heading %></h1>
    <p class="text-base md:text-lg mt-5 leading-relaxed text-brown"><%= @hero_subheading %></p>
    <p class="text-sm md:text-base mt-4 leading-relaxed max-w-lg mx-auto text-brown/80">
      From sizzling street tacos to hearty burritos loaded with your favorite fillings, every dish is made fresh with authentic Mexican recipes and the finest ingredients.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 mt-8 justify-center">
      <a href="/menu" class="text-sm font-semibold text-white px-9 py-3.5 rounded-full bg-deep-red hover:opacity-90">ORDER NOW →</a>
      <a href="tel:<%= @phone&.gsub(/[^0-9]/, '') %>" class="text-sm font-semibold px-9 py-3.5 rounded-full border-2 text-navy border-navy hover:opacity-80">Call to Order</a>
    </div>
  </div>

  <%# Bunting flags in top-right corner %>
  <div class="bunting-container">
    <div class="bunting-string"></div>
    <div class="bunting-flag left-[10px] bg-green -rotate-5"></div>
    <div class="bunting-flag left-[24px] bg-[#64B5F6] rotate-2"></div>
    <div class="bunting-flag left-[38px] bg-orange -rotate-3"></div>
    <div class="bunting-flag left-[52px] bg-[#F48FB1] rotate-4"></div>
    <div class="bunting-flag left-[66px] bg-green -rotate-2"></div>
    <div class="bunting-flag left-[80px] bg-[#64B5F6] rotate-3"></div>
  </div>
</section>
