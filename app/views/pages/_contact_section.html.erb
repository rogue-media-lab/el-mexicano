<%# Contact & Map %>
<section class="px-6 md:px-12 py-16 md:py-20 papel-picado bg-deep-red">
  <p class="text-xs font-medium uppercase tracking-[0.15em] text-center mb-2 text-gold">Come See Us</p>
  <h2 class="text-3xl md:text-4xl font-bold text-center mb-12 tracking-tight text-white font-display">Visit El Mexicano</h2>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-10 max-w-5xl mx-auto">
    <%# Hours %>
    <div>
      <h3 class="text-xs font-semibold uppercase tracking-[0.1em] mb-5 text-gold">Hours</h3>
      <div class="space-y-3">
        <% @hours.each do |h| %>
          <div class="flex justify-between">
            <span class="text-sm text-white/80"><%= h.day_name %></span>
            <span class="text-sm font-medium text-white"><%= h.formatted_hours %></span>
          </div>
        <% end %>
      </div>
    </div>

    <%# Contact %>
    <div>
      <h3 class="text-xs font-semibold uppercase tracking-[0.1em] mb-5 text-gold">Contact</h3>
      <p class="text-sm mb-1 text-white/80"><%= @address %></p>
      <a href="tel:<%= @phone&.gsub(/[^0-9]/, '') %>" class="text-lg font-semibold block mt-3 text-gold"><%= @phone %></a>
      <p class="text-sm mt-1 text-white/60"><%= @email %></p>
    </div>

    <%# Map %>
    <div>
      <h3 class="text-xs font-semibold uppercase tracking-[0.1em] mb-5 text-gold">Find Us</h3>
      <div class="aspect-square rounded-2xl overflow-hidden mb-5">
        <iframe src="https://maps.google.com/maps?q=El+Mexicano+401+N+Main+St+Clover+SC&t=&z=16&ie=UTF8&iwloc=&output=embed" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
      </div>
    </div>
  </div>
</section>
