<%# Our Story %>
<% if @about_heading.present? %>
<section class="px-6 md:px-12 py-16 md:py-20 papel-picado-multi bg-cream">
  <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center gap-12 md:gap-16">
    <div class="flex-1 max-w-lg">
      <p class="text-xs font-medium uppercase tracking-[0.1em] mb-3 text-deep-red">Our Story</p>
      <h2 class="text-3xl md:text-4xl font-bold leading-tight tracking-tight mb-5 text-navy font-display"><%= @about_heading %></h2>
      <p class="text-base leading-relaxed text-brown"><%= @about_body %></p>
    </div>
    <div class="flex-1 max-w-sm h-72 rounded-2xl overflow-hidden flex items-center justify-center bg-gradient-to-br from-gold to-deep-red">
      <div class="text-center">
        <%= image_tag "cactus.svg", class: "mx-auto mb-3 opacity-50 w-[60px]" %>
        <p class="text-2xl font-bold text-white font-display">El Mexicano</p>
        <p class="text-xs text-white opacity-60 mt-1 uppercase tracking-wider">Clover, SC</p>
      </div>
    </div>
  </div>
</section>
<% end %>
