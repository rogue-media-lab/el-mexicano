<!-- Hero -->
<section class="flex flex-col items-center justify-center px-6 md:px-12 py-16 md:py-24 relative overflow-hidden wavy-texture" style="background-color: var(--yellow); min-height: 500px;">
  <!-- Decorative food SVGs -->
  <%= image_tag "taco.svg", class: "absolute opacity-40 pointer-events-none", style: "width: 140px; left: 5%; top: 20%; transform: rotate(-15deg);" %>
  <%= image_tag "burrito.svg", class: "absolute opacity-35 pointer-events-none", style: "width: 120px; right: 5%; top: 25%; transform: rotate(10deg);" %>
  <%= image_tag "nachos.svg", class: "absolute opacity-30 pointer-events-none", style: "width: 110px; left: 12%; bottom: 15%; transform: rotate(-8deg);" %>
  <%= image_tag "taco.svg", class: "absolute opacity-25 pointer-events-none", style: "width: 100px; right: 12%; bottom: 20%; transform: rotate(20deg);" %>

  <!-- Centered text content -->
  <div class="max-w-2xl text-center z-10">
    <div class="w-16 h-1 rounded mb-6 mx-auto" style="background: var(--deep-red);"></div>
    <p class="text-sm font-medium uppercase tracking-[0.15em] mb-4" style="color: var(--deep-red);">Clover, South Carolina — Family Owned</p>
    <h1 class="text-4xl md:text-6xl font-bold leading-tight tracking-tight" style="color: var(--navy); font-family: 'Lilita One', cursive;"><%= @hero_heading %></h1>
    <p class="text-base md:text-lg mt-5 leading-relaxed" style="color: var(--brown);"><%= @hero_subheading %></p>
    <p class="text-sm md:text-base mt-4 leading-relaxed max-w-lg mx-auto" style="color: rgba(121,85,72,0.8);">
      From sizzling street tacos to hearty burritos loaded with your favorite fillings, every dish is made fresh with authentic Mexican recipes and the finest ingredients.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 mt-8 justify-center">
      <a href="/menu" class="text-sm font-semibold text-white px-9 py-3.5 rounded-full hover:opacity-90" style="background: var(--deep-red);">ORDER NOW →</a>
      <a href="tel:<%= @phone&.gsub(/[^0-9]/, '') %>" class="text-sm font-semibold px-9 py-3.5 rounded-full border-2 hover:opacity-80" style="color: var(--navy); border-color: var(--navy);">Call to Order</a>
    </div>
  </div>

  <!-- Bunting flags in top-right corner -->
  <div class="bunting-container">
    <div class="bunting-string"></div>
    <div class="bunting-flag" style="left: 10px; background: #66BB6A; transform: rotate(-5deg);"></div>
    <div class="bunting-flag" style="left: 24px; background: #64B5F6; transform: rotate(2deg);"></div>
    <div class="bunting-flag" style="left: 38px; background: #FBC02D; transform: rotate(-3deg);"></div>
    <div class="bunting-flag" style="left: 52px; background: #F48FB1; transform: rotate(4deg);"></div>
    <div class="bunting-flag" style="left: 66px; background: #66BB6A; transform: rotate(-2deg);"></div>
    <div class="bunting-flag" style="left: 80px; background: #64B5F6; transform: rotate(3deg);"></div>
  </div>
</section>

<!-- Red Promo Banner -->
<div class="promo-banner flex items-center justify-between px-6 md:px-12">
  <div class="flex items-center gap-4">
    <span class="text-3xl md:text-4xl">🌮</span>
    <div>
      <p class="text-sm md:text-base font-bold text-white uppercase tracking-wide">FREE CHIPS &amp; SALSA WITH EVERY ORDER</p>
      <p class="text-xs" style="color: rgba(255,255,255,0.7);">Dine-in or takeout — no purchase minimum</p>
    </div>
  </div>
  <a href="tel:<%= @phone&.gsub(/[^0-9]/, '') %>" class="text-sm font-bold text-white px-6 py-2.5 rounded-full hover:opacity-90 flex-shrink-0" style="background: var(--yellow); color: var(--navy);">
    <i class="fa-solid fa-phone mr-2"></i>Call Now
  </a>
</div>

<!-- Signature Favorites -->
<% if @featured_deals.any? || @featured_items.any? %>
<section class="px-6 md:px-12 pb-16 md:pb-20 relative" style="background: var(--navy);">
  <div class="grid grid-cols-1 md:grid-cols-3 gap-7 max-w-6xl mx-auto">
    <%# Show meal deals first, then individual featured items to fill remaining slots %>
    <% @featured_deals.each do |deal| %>
      <% deal_photo = FoodPhotos.for(deal.main_item.name) %>
      <div class="bg-white rounded-t-2xl rounded-b-2xl overflow-hidden" style="margin-top: -80px; position: relative; z-index: 10; box-shadow: 0 4px 24px rgba(0,0,0,0.25);">
        <div class="h-48 flex items-center justify-center relative" style="background: linear-gradient(135deg, var(--orange), var(--deep-red));">
          <% if deal_photo %>
            <%= image_tag deal_photo, class: "w-full h-full object-cover" %>
          <% else %>
            <span class="text-5xl opacity-30">🌮</span>
          <% end %>
          <span class="absolute top-3 right-3 text-xs font-bold px-3 py-1 rounded-full" style="background: var(--yellow); color: var(--navy);">COMBO</span>
        </div>
        <div class="p-6">
          <div class="flex items-center justify-between mb-2">
            <h3 class="text-lg font-bold" style="color: var(--navy);"><%= deal.name %></h3>
            <span class="text-lg font-bold" style="color: var(--deep-red);"><%= deal.formatted_price %></span>
          </div>
          <p class="text-sm mb-4 leading-relaxed" style="color: var(--brown);"><%= deal.main_item.name %> + <%= deal.default_side.name %> + Drink</p>
          <%= button_to "Add Meal to Cart", cart_add_meal_path(deal_id: deal.id), method: :post, class: "w-full text-sm font-semibold text-white px-4 py-2.5 rounded-full cursor-pointer hover:opacity-90", style: "background: var(--deep-red);" %>
        </div>
      </div>
    <% end %>
    <%# Fill remaining slots with individual featured items %>
    <% remaining = 3 - @featured_deals.size %>
    <% @featured_items.first(remaining).each do |item| %>
      <% item_photo = FoodPhotos.for(item.name) %>
      <div class="bg-white rounded-t-2xl rounded-b-2xl overflow-hidden" style="margin-top: -80px; position: relative; z-index: 10; box-shadow: 0 4px 24px rgba(0,0,0,0.25);">
        <div class="h-48 flex items-center justify-center" style="background: linear-gradient(135deg, var(--orange), var(--deep-red));">
          <% if item_photo %>
            <%= image_tag item_photo, class: "w-full h-full object-cover" %>
          <% else %>
            <span class="text-5xl opacity-30">🌮</span>
          <% end %>
        </div>
        <div class="p-6">
          <h3 class="text-lg font-bold" style="color: var(--navy);"><%= item.name %></h3>
          <p class="text-sm mt-2 leading-relaxed" style="color: var(--brown);"><%= item.description %></p>
        </div>
      </div>
    <% end %>
  </div>
</section>
<% end %>

<!-- Our Story -->
<% if @about_heading.present? %>
<section class="px-6 md:px-12 py-16 md:py-20 papel-picado-multi" style="background: #FFF8E1;">
  <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center gap-12 md:gap-16">
    <div class="flex-1 max-w-lg">
      <p class="text-xs font-medium uppercase tracking-[0.1em] mb-3" style="color: var(--deep-red);">Our Story</p>
      <h2 class="text-3xl md:text-4xl font-bold leading-tight tracking-tight mb-5" style="color: var(--navy); font-family: 'Lilita One', cursive;"><%= @about_heading %></h2>
      <p class="text-base leading-relaxed" style="color: var(--brown);"><%= @about_body %></p>
    </div>
    <div class="flex-1 max-w-sm h-72 rounded-2xl overflow-hidden flex items-center justify-center" style="background: linear-gradient(135deg, #FDD835, #A10035);">
      <div class="text-center">
        <%= image_tag "cactus.svg", class: "mx-auto mb-3 opacity-50", style: "width: 60px;" %>
        <p class="text-2xl font-bold text-white" style="font-family: 'Lilita One', cursive;">El Mexicano</p>
        <p class="text-xs text-white opacity-60 mt-1 uppercase tracking-wider">Clover, SC</p>
      </div>
    </div>
  </div>
</section>
<% end %>

<!-- Menu Preview -->
<section class="px-6 md:px-12 py-16 md:py-20" style="background: var(--navy);">
  <p class="text-xs font-medium uppercase tracking-[0.15em] text-center mb-2" style="color: var(--yellow);">What We Serve</p>
  <h2 class="text-3xl md:text-4xl font-bold text-center mb-4 tracking-tight" style="color: var(--white); font-family: 'Lilita One', cursive;">Our Menu</h2>
  <p class="text-base text-center max-w-lg mx-auto mb-12" style="color: rgba(255,255,255,0.6);">Authentic Mexican favorites — fresh ingredients, bold flavors, and generous portions at honest prices.</p>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-10 max-w-6xl mx-auto">
    <% @categories.limit(3).each do |cat| %>
      <div>
        <h3 class="text-lg font-bold pb-3 mb-5" style="color: var(--yellow); border-bottom: 1px solid rgba(253,216,53,0.3); font-family: 'Lilita One', cursive;"><%= cat.name %></h3>
        <div class="space-y-3.5">
          <% cat.menu_items.active.limit(7).each do |item| %>
            <div class="flex justify-between items-baseline">
              <span class="text-sm font-medium" style="color: var(--white);"><%= item.name %></span>
              <span class="text-sm" style="color: rgba(255,255,255,0.5);"><%= item.formatted_price %></span>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="text-center mt-10">
    <a href="/menu" class="text-sm font-medium uppercase tracking-wider pb-0.5 hover:opacity-80" style="color: var(--yellow); border-bottom: 1px solid var(--yellow);">View Full Menu →</a>
  </div>
</section>

<!-- Reviews -->
<section class="px-6 md:px-12 py-16 md:py-20" style="background: var(--off-white);">
  <p class="text-xs font-medium uppercase tracking-[0.15em] text-center mb-2" style="color: var(--deep-red);">What People Say</p>
  <h2 class="text-3xl md:text-4xl font-bold text-center mb-4 tracking-tight" style="color: var(--navy); font-family: 'Lilita One', cursive;">Our Guests Love Us</h2>

  <% if @google_reviews %>
    <div class="flex items-center justify-center gap-3 mb-10">
      <span class="text-3xl font-bold" style="color: var(--navy);"><%= @google_reviews[:rating] %></span>
      <div>
        <div class="flex gap-0.5">
          <% @google_reviews[:rating].to_i.times do %><span style="color: var(--orange);">★</span><% end %>
          <% (5 - @google_reviews[:rating].to_i).times do %><span style="color: rgba(251,192,45,0.3);">★</span><% end %>
        </div>
        <p class="text-xs" style="color: var(--brown);">Google Reviews · <%= @google_reviews[:total] %> reviews</p>
      </div>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-7 max-w-6xl mx-auto">
    <% reviews = @google_reviews&.dig(:reviews) || @testimonials.map { |t| { author: t.customer_name, rating: t.stars, text: t.quote } } %>
    <% reviews.first(3).each do |r| %>
      <div class="bg-white rounded-2xl p-8" style="border-left: 4px solid var(--green);">
        <div class="flex gap-1 mb-4">
          <% r[:rating].to_i.times do %><span style="color: var(--orange);">★</span><% end %>
        </div>
        <p class="text-sm leading-relaxed italic mb-5" style="color: var(--navy);">"<%= r[:text] %>"</p>
        <div class="flex items-center justify-between">
          <p class="text-sm font-semibold" style="color: var(--deep-red);">— <%= r[:author] %></p>
          <% if r[:time] %><p class="text-xs" style="color: rgba(121,85,72,0.5);"><%= r[:time] %></p><% end %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="text-center mt-10">
    <p class="text-xs font-medium uppercase tracking-[0.15em] mb-4" style="color: var(--deep-red);">Leave a Review</p>
    <div class="flex items-center justify-center gap-6">
      <!-- Google -->
      <a href="https://www.google.com/maps/place/?q=place_id:ChIJeTI3VEvsVogR39K1AcGkr2Y" target="_blank" class="flex flex-col items-center gap-2 group">
        <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center shadow-sm group-hover:shadow-md transition-shadow">
          <i class="fa-brands fa-google text-xl" style="color: #4285F4;"></i>
        </div>
        <span class="text-xs group-hover:opacity-100" style="color: rgba(26,35,126,0.6);">Google</span>
      </a>
      <!-- Yelp -->
      <a href="#" target="_blank" class="flex flex-col items-center gap-2 group">
        <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center shadow-sm group-hover:shadow-md transition-shadow">
          <i class="fa-brands fa-yelp text-xl" style="color: #D32323;"></i>
        </div>
        <span class="text-xs group-hover:opacity-100" style="color: rgba(26,35,126,0.6);">Yelp</span>
      </a>
      <!-- Facebook -->
      <a href="#" target="_blank" class="flex flex-col items-center gap-2 group">
        <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center shadow-sm group-hover:shadow-md transition-shadow">
          <i class="fa-brands fa-facebook text-xl" style="color: #1877F2;"></i>
        </div>
        <span class="text-xs group-hover:opacity-100" style="color: rgba(26,35,126,0.6);">Facebook</span>
      </a>
    </div>
  </div>
</section>

<!-- Contact & Map -->
<section class="px-6 md:px-12 py-16 md:py-20 papel-picado" style="background: var(--deep-red);">
  <p class="text-xs font-medium uppercase tracking-[0.15em] text-center mb-2" style="color: var(--yellow);">Come See Us</p>
  <h2 class="text-3xl md:text-4xl font-bold text-center mb-12 tracking-tight" style="color: var(--white); font-family: 'Lilita One', cursive;">Visit El Mexicano</h2>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-10 max-w-5xl mx-auto">
    <!-- Hours -->
    <div>
      <h3 class="text-xs font-semibold uppercase tracking-[0.1em] mb-5" style="color: var(--yellow);">Hours</h3>
      <div class="space-y-3">
        <% @hours.each do |h| %>
          <div class="flex justify-between">
            <span class="text-sm" style="color: rgba(255,255,255,0.8);"><%= h.day_name %></span>
            <span class="text-sm font-medium" style="color: var(--white);"><%= h.formatted_hours %></span>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Contact -->
    <div>
      <h3 class="text-xs font-semibold uppercase tracking-[0.1em] mb-5" style="color: var(--yellow);">Contact</h3>
      <p class="text-sm mb-1" style="color: rgba(255,255,255,0.8);"><%= @address %></p>
      <a href="tel:<%= @phone&.gsub(/[^0-9]/, '') %>" class="text-lg font-semibold block mt-3" style="color: var(--yellow);"><%= @phone %></a>
      <p class="text-sm mt-1" style="color: rgba(255,255,255,0.6);"><%= @email %></p>
    </div>

    <!-- Map -->
    <div>
      <h3 class="text-xs font-semibold uppercase tracking-[0.1em] mb-5" style="color: var(--yellow);">Find Us</h3>
      <div class="aspect-square rounded-2xl overflow-hidden">
        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3268.5!2d-81.1935!3d35.1128!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0xChIJeTI3VEvsVogR39K1AcGkr2Y!2sEl+Mexicano!5e0!3m2!1sen!2sus!4v1" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
      </div>
    </div>
  </div>
</section>
