<%# Reviews %>
<section class="px-6 md:px-12 py-16 md:py-20 bg-cream">
  <p class="text-xs font-medium uppercase tracking-[0.15em] text-center mb-2 text-deep-red">What People Say</p>
  <h2 class="text-3xl md:text-4xl font-bold text-center mb-4 tracking-tight text-navy font-display">Our Guests Love Us</h2>

  <% if @google_reviews %>
    <div class="flex items-center justify-center gap-3 mb-10">
      <span class="text-3xl font-bold text-navy"><%= @google_reviews[:rating] %></span>
      <div>
        <div class="flex gap-0.5">
          <% @google_reviews[:rating].to_i.times do %><span class="text-orange">★</span><% end %>
          <% (5 - @google_reviews[:rating].to_i).times do %><span class="text-orange/30">★</span><% end %>
        </div>
        <p class="text-xs text-brown">Google Reviews · <%= @google_reviews[:total] %> reviews</p>
      </div>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-7 max-w-6xl mx-auto">
    <% reviews = @google_reviews&.dig(:reviews) || @testimonials.map { |t| { author: t.customer_name, rating: t.stars, text: t.quote } } %>
    <% reviews.first(3).each do |r| %>
      <div class="bg-white rounded-2xl p-8 border-l-4 border-green">
        <div class="flex gap-1 mb-4">
          <% r[:rating].to_i.times do %><span class="text-orange">★</span><% end %>
        </div>
        <p class="text-sm leading-relaxed italic mb-5 text-navy">"<%= r[:text] %>"</p>
        <div class="flex items-center justify-between">
          <p class="text-sm font-semibold text-deep-red">— <%= r[:author] %></p>
          <% if r[:time] %><p class="text-xs text-brown/50"><%= r[:time] %></p><% end %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="text-center mt-10">
    <p class="text-xs font-medium uppercase tracking-[0.15em] mb-4 text-deep-red">Leave a Review</p>
    <div class="flex items-center justify-center gap-6">
      <%# Google %>
      <a href="https://www.google.com/maps/place/?q=place_id:ChIJeTI3VEvsVogR39K1AcGkr2Y" target="_blank" class="flex flex-col items-center gap-2 group">
        <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center shadow-sm group-hover:shadow-md transition-shadow">
          <i class="fa-brands fa-google text-xl text-[#4285F4]"></i>
        </div>
        <span class="text-xs text-navy/60 group-hover:opacity-100">Google</span>
      </a>
      <%# Yelp %>
      <a href="#" target="_blank" class="flex flex-col items-center gap-2 group">
        <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center shadow-sm group-hover:shadow-md transition-shadow">
          <i class="fa-brands fa-yelp text-xl text-[#D32323]"></i>
        </div>
        <span class="text-xs text-navy/60 group-hover:opacity-100">Yelp</span>
      </a>
      <%# Facebook %>
      <a href="#" target="_blank" class="flex flex-col items-center gap-2 group">
        <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center shadow-sm group-hover:shadow-md transition-shadow">
          <i class="fa-brands fa-facebook text-xl text-[#1877F2]"></i>
        </div>
        <span class="text-xs text-navy/60 group-hover:opacity-100">Facebook</span>
      </a>
    </div>
  </div>
</section>
