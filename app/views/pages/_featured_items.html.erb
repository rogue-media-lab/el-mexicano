<%# Signature Favorites %>
<% if @featured_deals.any? || @featured_items.any? %>
<section class="px-6 md:px-12 py-16 md:py-24 bg-navy">
  <div class="max-w-6xl mx-auto">
    <p class="text-xs font-medium uppercase tracking-[0.15em] text-center mb-2 text-gold">From Our Kitchen</p>
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-12 tracking-tight text-white font-display">Signature Favorites</h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-7">
      <% @featured_deals.each do |deal| %>
        <% deal_photo = FoodPhotos.for(deal.main_item.name) %>
        <div class="bg-white overflow-hidden rounded-2xl shadow-lg hover:-translate-y-1 hover:shadow-xl transition-all duration-200">
          <div class="h-56 flex items-center justify-center relative bg-gradient-to-br from-orange to-deep-red">
            <% if deal_photo %>
              <%= image_tag deal_photo, class: "w-full h-full object-cover" %>
            <% else %>
              <span class="text-5xl opacity-30">🌮</span>
            <% end %>
            <span class="absolute top-3 right-3 text-xs font-bold px-3 py-1 rounded-full bg-gold text-navy">COMBO</span>
          </div>
          <div class="p-6">
            <div class="flex items-center justify-between mb-2">
              <h3 class="text-lg font-bold text-navy"><%= deal.name %></h3>
              <span class="text-lg font-bold text-deep-red"><%= deal.formatted_price %></span>
            </div>
            <p class="text-sm mb-4 leading-relaxed text-brown"><%= deal.main_item.name %> + <%= deal.default_side.name %> + Drink</p>
            <%= button_to "Add Meal to Cart", cart_add_meal_path(deal_id: deal.id), method: :post, class: "w-full text-sm font-semibold text-white px-4 py-2.5 rounded-full cursor-pointer bg-deep-red hover:opacity-90" %>
          </div>
        </div>
      <% end %>

      <% remaining = 3 - @featured_deals.size %>
      <% @featured_items.first(remaining).each do |item| %>
        <% item_photo = FoodPhotos.for(item.name) %>
        <div class="bg-white overflow-hidden rounded-2xl shadow-lg hover:-translate-y-1 hover:shadow-xl transition-all duration-200">
          <div class="h-56 flex items-center justify-center bg-gradient-to-br from-orange to-deep-red">
            <% if item_photo %>
              <%= image_tag item_photo, class: "w-full h-full object-cover" %>
            <% else %>
              <span class="text-5xl opacity-30">🌮</span>
            <% end %>
          </div>
          <div class="p-6">
            <h3 class="text-lg font-bold text-navy"><%= item.name %></h3>
            <p class="text-sm mt-2 leading-relaxed text-brown"><%= item.description %></p>
          </div>
        </div>
      <% end %>
    </div>

    <div class="text-center mt-10">
      <a href="/menu" class="text-sm font-medium uppercase tracking-wider pb-0.5 text-gold border-b border-gold hover:opacity-80">View Full Menu →</a>
    </div>
  </div>
</section>
<% end %>
