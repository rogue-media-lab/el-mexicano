<section class="px-6 md:px-12 py-16 md:py-20 bg-deep-red min-h-screen">
  <p class="text-xs font-medium text-gold uppercase tracking-[0.15em] text-center mb-2">Come See Us</p>
  <h1 class="text-3xl md:text-5xl font-bold text-cream text-center mb-16 tracking-tight font-display">Visit El Mexicano</h1>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-10 max-w-5xl mx-auto">
    <%# Hours %>
    <div>
      <h2 class="text-xs font-semibold text-gold uppercase tracking-[0.1em] mb-5">Hours</h2>
      <div class="space-y-3">
        <% @hours.each do |h| %>
          <div class="flex justify-between">
            <span class="text-sm text-cream/80"><%= h.day_name %></span>
            <span class="text-sm font-medium text-cream"><%= h.formatted_hours %></span>
          </div>
        <% end %>
      </div>
    </div>

    <%# Contact %>
    <div>
      <h2 class="text-xs font-semibold text-gold uppercase tracking-[0.1em] mb-5">Contact</h2>
      <p class="text-sm text-cream/80 mb-1"><%= @address %></p>
      <a href="tel:<%= @phone&.gsub(/[^0-9]/, '') %>" class="text-xl font-semibold text-gold block mt-4"><%= @phone %></a>
      <a href="mailto:<%= @email %>" class="text-sm text-cream/60 mt-2 block hover:text-cream/80"><%= @email %></a>
      <div class="mt-6">
        <a href="tel:<%= @phone&.gsub(/[^0-9]/, '') %>" class="inline-block text-sm font-semibold text-deep-red bg-gold px-8 py-3 rounded-full">Call Now</a>
      </div>
    </div>

    <%# Map %>
    <div>
      <h2 class="text-xs font-semibold text-gold uppercase tracking-[0.1em] mb-5">Find Us</h2>
      <div class="aspect-square rounded-2xl overflow-hidden">
        <iframe src="https://maps.google.com/maps?q=El+Mexicano+401+N+Main+St+Clover+SC&t=&z=16&ie=UTF8&iwloc=&output=embed" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
      </div>
    </div>
  </div>
</section>
