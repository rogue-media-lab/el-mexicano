<!DOCTYPE html>
<html>
<head>
  <title>Admin — Italian Garden</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
</head>
<body class="bg-gray-100 text-gray-900 min-h-screen">
  <div class="flex min-h-screen">
    <!-- Sidebar -->
    <aside class="w-64 bg-gray-900 text-gray-100 flex-shrink-0 flex flex-col">
      <div class="p-6 border-b border-gray-700">
        <h1 class="text-lg font-bold text-amber-400">Italian Garden</h1>
        <p class="text-xs text-gray-400 mt-1">Admin Dashboard</p>
      </div>
      <nav class="flex-1 p-4 space-y-1">
        <%= link_to admin_root_path, class: "flex items-center gap-3 px-3 py-2 rounded hover:bg-gray-800 #{controller_name == 'dashboard' ? 'bg-gray-800 text-amber-400' : 'text-gray-300'}" do %>
          <span>Dashboard</span>
        <% end %>
        <%= link_to admin_menu_categories_path, class: "flex items-center gap-3 px-3 py-2 rounded hover:bg-gray-800 #{controller_name == 'menu_categories' ? 'bg-gray-800 text-amber-400' : 'text-gray-300'}" do %>
          <span>Menu Categories</span>
        <% end %>
        <%= link_to admin_menu_items_path, class: "flex items-center gap-3 px-3 py-2 rounded hover:bg-gray-800 #{controller_name == 'menu_items' ? 'bg-gray-800 text-amber-400' : 'text-gray-300'}" do %>
          <span>Menu Items</span>
        <% end %>
        <%= link_to edit_admin_hours_path, class: "flex items-center gap-3 px-3 py-2 rounded hover:bg-gray-800 #{controller_name == 'hours' ? 'bg-gray-800 text-amber-400' : 'text-gray-300'}" do %>
          <span>Hours</span>
        <% end %>
        <%= link_to admin_testimonials_path, class: "flex items-center gap-3 px-3 py-2 rounded hover:bg-gray-800 #{controller_name == 'testimonials' ? 'bg-gray-800 text-amber-400' : 'text-gray-300'}" do %>
          <span>Testimonials</span>
        <% end %>
        <%= link_to admin_reservations_path, class: "flex items-center gap-3 px-3 py-2 rounded hover:bg-gray-800 #{controller_name == 'reservations' ? 'bg-gray-800 text-amber-400' : 'text-gray-300'}" do %>
          <span>Reservations</span>
        <% end %>
        <%= link_to admin_orders_path, class: "flex items-center gap-3 px-3 py-2 rounded hover:bg-gray-800 #{controller_name == 'orders' ? 'bg-gray-800 text-amber-400' : 'text-gray-300'}" do %>
          <span>Orders</span>
        <% end %>
        <%= link_to admin_meal_deals_path, class: "flex items-center gap-3 px-3 py-2 rounded hover:bg-gray-800 #{controller_name == 'meal_deals' ? 'bg-gray-800 text-amber-400' : 'text-gray-300'}" do %>
          <span>Meal Deals</span>
        <% end %>
        <%= link_to edit_admin_site_settings_path, class: "flex items-center gap-3 px-3 py-2 rounded hover:bg-gray-800 #{controller_name == 'site_settings' ? 'bg-gray-800 text-amber-400' : 'text-gray-300'}" do %>
          <span>Site Settings</span>
        <% end %>
      </nav>
      <div class="p-4 border-t border-gray-700">
        <%= link_to root_path, class: "text-sm text-gray-400 hover:text-gray-200" do %>
          View Site
        <% end %>
        <span class="text-gray-600 mx-2">|</span>
        <%= button_to "Sign Out", destroy_user_session_path, method: :delete, class: "text-sm text-gray-400 hover:text-gray-200 bg-transparent border-0 cursor-pointer p-0" %>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 p-8 overflow-y-auto">
      <% if notice.present? %>
        <div data-controller="toast" class="fixed top-20 right-4 z-50 max-w-sm bg-green-50 border border-green-200 text-green-800 rounded-lg px-4 py-3 text-sm shadow-lg" style="transform:translateX(120%);opacity:0">
          <div class="flex items-center gap-2">
            <span class="flex-1"><%= notice %></span>
            <button data-action="click->toast#dismiss" class="text-green-400 hover:text-green-600">&times;</button>
          </div>
        </div>
      <% end %>
      <% if alert.present? %>
        <div data-controller="toast" class="fixed top-20 right-4 z-50 max-w-sm bg-red-50 border border-red-200 text-red-800 rounded-lg px-4 py-3 text-sm shadow-lg" style="transform:translateX(120%);opacity:0">
          <div class="flex items-center gap-2">
            <span class="flex-1"><%= alert %></span>
            <button data-action="click->toast#dismiss" class="text-red-400 hover:text-red-600">&times;</button>
          </div>
        </div>
      <% end %>

      <%= yield %>
    </main>
  </div>
</body>
</html>
