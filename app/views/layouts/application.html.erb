<!DOCTYPE html>
<html>
<head>
  <title>El Mexicano — Authentic Mexican Restaurant in Clover, SC</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="El Mexicano — Authentic Mexican restaurant in Clover, SC. Fresh tacos, burritos, enchiladas, and more. Family-friendly dining at 401 N Main St.">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <link href="https://fonts.googleapis.com/css2?family=Lilita+One&family=Nunito:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
</head>
<body class="min-h-screen bg-[#7A0028] font-body text-brown">
  <div class="navy-frame">
    <%= render "shared/navbar" %>
    <%= render "shared/flash_messages" %>

    <main>
      <%= yield %>
    </main>

    <%= render "shared/footer" %>
  </div>
</body>
</html>
