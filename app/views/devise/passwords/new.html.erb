<div class="min-h-screen flex flex-col items-center justify-center px-6" style="background: var(--deep-red);">
  <div class="mb-8 text-center">
    <h1 class="text-2xl font-bold" style="font-family: 'Lilita One', cursive; color: var(--white);">El Mexicano</h1>
    <p class="text-sm uppercase tracking-wider mt-1" style="color: var(--yellow);">Admin</p>
  </div>

  <div class="w-full max-w-sm rounded-2xl shadow-lg p-8" style="background: var(--off-white);">
    <h2 class="text-xl font-bold mb-2 text-center" style="font-family: 'Lilita One', cursive; color: var(--navy);">Forgot Your Password?</h2>
    <p class="text-sm text-center mb-6" style="color: var(--brown);">Enter your email and we'll send reset instructions.</p>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :email, class: "block text-sm font-medium mb-1", style: "color: var(--navy);" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full border rounded px-3 py-2.5 bg-white focus:ring-2 outline-none text-sm", style: "border-color: rgba(161,0,53,0.3); color: var(--navy);" %>
      </div>

      <div class="mt-6">
        <%= f.submit "Send Reset Link", class: "w-full text-white font-semibold py-2.5 rounded-full cursor-pointer hover:opacity-90 text-sm", style: "background: var(--deep-red);" %>
      </div>
    <% end %>

    <div class="mt-6 pt-4 text-center" style="border-top: 1px solid rgba(161,0,53,0.15);">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
