<div class="min-h-screen flex flex-col items-center justify-center px-6" style="background: var(--deep-red);">
  <div class="mb-8 text-center">
    <h1 class="text-2xl font-bold" style="font-family: 'Lilita One', cursive; color: var(--white);">El Mexicano</h1>
    <p class="text-sm uppercase tracking-wider mt-1" style="color: var(--yellow);">Admin</p>
  </div>

  <div class="w-full max-w-sm rounded-2xl shadow-lg p-8" style="background: var(--off-white);">
    <h2 class="text-xl font-bold mb-6 text-center" style="font-family: 'Lilita One', cursive; color: var(--navy);">Set New Password</h2>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <%= f.hidden_field :reset_password_token %>

      <div class="space-y-4">
        <div>
          <%= f.label :password, "New password", class: "block text-sm font-medium mb-1", style: "color: var(--navy);" %>
          <% if @minimum_password_length %>
            <p class="text-xs mb-1" style="color: var(--brown);"><%= @minimum_password_length %> characters minimum</p>
          <% end %>
          <%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: "w-full border rounded px-3 py-2.5 bg-white focus:ring-2 outline-none text-sm", style: "border-color: rgba(161,0,53,0.3); color: var(--navy);" %>
        </div>

        <div>
          <%= f.label :password_confirmation, "Confirm new password", class: "block text-sm font-medium mb-1", style: "color: var(--navy);" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full border rounded px-3 py-2.5 bg-white focus:ring-2 outline-none text-sm", style: "border-color: rgba(161,0,53,0.3); color: var(--navy);" %>
        </div>
      </div>

      <div class="mt-6">
        <%= f.submit "Update Password", class: "w-full text-white font-semibold py-2.5 rounded-full cursor-pointer hover:opacity-90 text-sm", style: "background: var(--deep-red);" %>
      </div>
    <% end %>

    <div class="mt-6 pt-4 text-center" style="border-top: 1px solid rgba(161,0,53,0.15);">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
