<div class="min-h-screen flex flex-col items-center justify-center px-6" style="background: var(--deep-red);">
  <div class="mb-8 text-center">
    <h1 class="text-2xl font-bold" style="font-family: 'Lilita One', cursive; color: var(--white);">El Mexicano</h1>
    <p class="text-sm uppercase tracking-wider mt-1" style="color: var(--yellow);">Admin</p>
  </div>

  <div class="w-full max-w-sm rounded-2xl shadow-lg p-8" style="background: var(--off-white);">
    <h2 class="text-xl font-bold mb-6 text-center" style="font-family: 'Lilita One', cursive; color: var(--navy);">Sign In</h2>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="space-y-4">
        <div>
          <%= f.label :email, class: "block text-sm font-medium mb-1", style: "color: var(--navy);" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full border rounded px-3 py-2.5 bg-white focus:ring-2 outline-none text-sm", style: "border-color: rgba(161,0,53,0.3); color: var(--navy); focus:ring-color: var(--yellow);" %>
        </div>

        <div>
          <%= f.label :password, class: "block text-sm font-medium mb-1", style: "color: var(--navy);" %>
          <%= f.password_field :password, autocomplete: "current-password", class: "w-full border rounded px-3 py-2.5 bg-white focus:ring-2 outline-none text-sm", style: "border-color: rgba(161,0,53,0.3); color: var(--navy);" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="flex items-center gap-2">
            <%= f.check_box :remember_me, class: "rounded", style: "border-color: rgba(161,0,53,0.3); color: var(--deep-red);" %>
            <%= f.label :remember_me, class: "text-sm", style: "color: var(--brown);" %>
          </div>
        <% end %>
      </div>

      <div class="mt-6">
        <%= f.submit "Sign In", class: "w-full text-white font-semibold py-2.5 rounded-full cursor-pointer hover:opacity-90 text-sm", style: "background: var(--deep-red);" %>
      </div>
    <% end %>

    <div class="mt-6 pt-4 text-center" style="border-top: 1px solid rgba(161,0,53,0.15);">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
