<div class="min-h-screen flex flex-col items-center justify-center px-6 bg-deep-red">
  <div class="mb-8 text-center">
    <h1 class="text-2xl font-bold font-display text-white">El Mexicano</h1>
    <p class="text-sm uppercase tracking-wider mt-1 text-gold">Admin</p>
  </div>

  <div class="w-full max-w-sm rounded-2xl shadow-lg p-8 bg-cream">
    <h2 class="text-xl font-bold mb-6 text-center font-display text-navy">Create Account</h2>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="space-y-4">
        <div>
          <%= f.label :email, class: "block text-sm font-medium mb-1 text-navy" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full border border-deep-red/30 rounded px-3 py-2.5 bg-white focus:ring-2 focus:ring-gold outline-none text-sm text-navy" %>
        </div>

        <div>
          <%= f.label :password, class: "block text-sm font-medium mb-1 text-navy" %>
          <% if @minimum_password_length %>
            <p class="text-xs mb-1 text-brown"><%= @minimum_password_length %> characters minimum</p>
          <% end %>
          <%= f.password_field :password, autocomplete: "new-password", class: "w-full border border-deep-red/30 rounded px-3 py-2.5 bg-white focus:ring-2 focus:ring-gold outline-none text-sm text-navy" %>
        </div>

        <div>
          <%= f.label :password_confirmation, class: "block text-sm font-medium mb-1 text-navy" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full border border-deep-red/30 rounded px-3 py-2.5 bg-white focus:ring-2 focus:ring-gold outline-none text-sm text-navy" %>
        </div>
      </div>

      <div class="mt-6">
        <%= f.submit "Create Account", class: "w-full text-white font-semibold py-2.5 rounded-full cursor-pointer bg-deep-red hover:opacity-90 text-sm" %>
      </div>
    <% end %>

    <div class="mt-6 pt-4 text-center border-t border-deep-red/15">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
